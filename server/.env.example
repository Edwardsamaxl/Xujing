# ============================================================
# 叙境 server 环境变量模板
# 复制本文件为 server/.env 后填入真实值。.env 已在 .gitignore 中。
# ============================================================

# -- 数据库 ---------------------------------------------------
# 必填。Postgres 连接串，本地默认即可。
DATABASE_URL="postgresql://user:password@localhost:5432/xujing"

# -- DeepSeek（剧情生成 + 语音问答 LLM） -----------------------
# 必填。控制台：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""
# 可选。一般不用改，特殊网络下可改成代理网关。
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# -- 百度 ASR（语音识别，叙述页麦克风需要） -------------------
# 必填。控制台：https://console.bce.baidu.com/ai/#/ai/speech/overview/index
# 创建"语音技术"应用 → 取 API Key / Secret Key（不是 AppID）
BAIDU_ASR_API_KEY=""
BAIDU_ASR_SECRET_KEY=""

# -- ffmpeg 路径（音频转码用，Web 端 webm/m4a → 16k 单声道 PCM）---
# 可选。留空时按以下顺序回退：
#   1. PATH 中的 ffmpeg（Homebrew/apt 装的）
#   2. node_modules 里的 ffmpeg-static
# 国内网络下 ffmpeg-static 的 postinstall 经常下载失败 / 被 Gatekeeper
# 拦截，建议自行安装并在这里指定绝对路径，例如：
#   macOS:  brew install ffmpeg  →  /opt/homebrew/bin/ffmpeg
#   Linux:  apt install ffmpeg   →  /usr/bin/ffmpeg
FFMPEG_PATH=""

# -- 服务端口 ------------------------------------------------
# 可选，默认 3000。
PORT=3000
